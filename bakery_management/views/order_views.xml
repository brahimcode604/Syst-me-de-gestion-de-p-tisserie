<!-- TODO: ajouter les filtres par mois -->
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             VUE LIST — Commandes
        ═══════════════════════════════════════════════════════════════════ -->
        <record id="view_bakery_order_list" model="ir.ui.view">
            <field name="name">bakery.order.list</field>
            <field name="model">bakery.order</field>
            <field name="arch" type="xml">
                <list string="Commandes"
                      decoration-info="state == 'confirmed'"
                      decoration-warning="state == 'production'"
                      decoration-success="state == 'done'"
                      decoration-danger="state == 'cancelled'">
                    <field name="name" string="Référence"/>
                    <field name="partner_id" string="Client"/>
                    <field name="date_order" string="Date commande"/>
                    <field name="date_delivery" string="Livraison prévue"/>
                    <field name="amount_total" string="Total (MAD)" sum="Total général"/>
                    <field name="state" widget="badge"
                           decoration-secondary="state == 'draft'"
                           decoration-info="state == 'confirmed'"
                           decoration-warning="state == 'production'"
                           decoration-primary="state == 'ready'"
                           decoration-success="state == 'done'"
                           decoration-danger="state == 'cancelled'"/>
                    <field name="invoice_status" widget="badge"
                           decoration-success="invoice_status == 'invoiced'"
                           decoration-warning="invoice_status == 'partial'"
                           decoration-secondary="invoice_status == 'not_invoiced'"
                           string="Facturation"/>
                    <field name="invoice_count" string="Factures"/>
                </list>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             VUE KANBAN — Commandes (groupé par état)
        ═══════════════════════════════════════════════════════════════════ -->
        <record id="view_bakery_order_kanban" model="ir.ui.view">
            <field name="name">bakery.order.kanban</field>
            <field name="model">bakery.order</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="amount_total"/>
                    <field name="state"/>
                    <field name="date_order"/>
                    <field name="date_delivery"/>
                    <field name="invoice_count"/>
                    <field name="invoice_status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content p-2">
                                    <div class="o_kanban_record_title">
                                        <strong><t t-esc="record.name.value"/></strong>
                                    </div>
                                    <div class="text-muted" style="font-size:13px;">
                                        👤 <t t-esc="record.partner_id.value"/>
                                    </div>
                                    <hr class="mt-1 mb-1"/>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong style="color:#c8956c;font-size:15px;">
                                            <t t-esc="record.amount_total.value"/> MAD
                                        </strong>
                                        <span t-if="record.invoice_count.raw_value > 0"
                                              class="badge text-bg-success"
                                              style="font-size:10px;">
                                            💰 Facturée
                                        </span>
                                    </div>
                                    <div t-if="record.date_delivery.value"
                                         class="text-muted mt-1" style="font-size:11px;">
                                        📦 Livraison : <t t-esc="record.date_delivery.value"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             VUE FORM — Commande
        ═══════════════════════════════════════════════════════════════════ -->
        <record id="view_bakery_order_form" model="ir.ui.view">
            <field name="name">bakery.order.form</field>
            <field name="model">bakery.order</field>
            <field name="arch" type="xml">
                <form string="Commande Pâtisserie">
                    <header>
                        <!-- Workflow -->
                        <button name="action_confirm"
                                string="✅ Confirmer"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_start_production"
                                string="🏭 Mettre en production"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'confirmed'"/>
                        <button name="action_ready"
                                string="✨ Commande prête"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'production'"/>
                        <button name="action_done"
                                string="🚀 Livrer"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'ready'"/>
                        <button name="action_cancel"
                                string="❌ Annuler"
                                type="object"
                                class="btn-danger"
                                invisible="state in ['done', 'cancelled']"/>
                        <button name="action_draft"
                                string="↩ Remettre en brouillon"
                                type="object"
                                invisible="state != 'cancelled'"/>

                        <!-- Facturation -->
                        <button name="action_create_invoice"
                                string="💰 Créer la facture"
                                type="object"
                                class="btn-secondary"
                                invisible="state not in ['ready', 'done'] or invoice_count > 0"
                                groups="bakery_management.group_bakery_admin"/>

                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,production,ready,done"/>
                    </header>
                    <sheet>
                        <!-- Boutons statistiques -->
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_invoices"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o"
                                    invisible="invoice_count == 0">
                                <field name="invoice_count" widget="statinfo"
                                       string="Factures"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <label for="name" string="Référence"/>
                            <h1>
                                <field name="name" readonly="1"
                                       placeholder="Auto-généré à la confirmation"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Client &amp; Échéances">
                                <field name="partner_id"
                                       options="{'no_create': True}"/>
                                <field name="date_order"/>
                                <field name="date_delivery"/>
                            </group>
                            <group string="Facturation">
                                <field name="invoice_status" readonly="1"
                                       widget="badge"
                                       decoration-success="invoice_status == 'invoiced'"
                                       decoration-warning="invoice_status == 'partial'"
                                       decoration-secondary="invoice_status == 'not_invoiced'"/>
                                <field name="invoice_count" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- Lignes produits -->
                            <page string="🛒 Produits commandés" name="order_lines">
                                <field name="order_line_ids"
                                       readonly="state in ['done', 'cancelled']">
                                    <list editable="bottom">
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"
                                               string="Prix unitaire (MAD)"/>
                                        <field name="subtotal" readonly="1"
                                               string="Sous-total (MAD)"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="amount_total"
                                           string="Total commande (MAD)"
                                           readonly="1"
                                           class="oe_subtotal_footer_separator"/>
                                </group>
                            </page>

                            <!-- Notes -->
                            <page string="📝 Notes" name="notes">
                                <field name="notes" nolabel="1"
                                       placeholder="Instructions spéciales, allergies, personnalisation du décor..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             VUE SEARCH — Commandes
        ═══════════════════════════════════════════════════════════════════ -->
        <record id="view_bakery_order_search" model="ir.ui.view">
            <field name="name">bakery.order.search</field>
            <field name="model">bakery.order</field>
            <field name="arch" type="xml">
                <search string="Rechercher une commande">
                    <field name="name" string="Référence"/>
                    <field name="partner_id" string="Client"/>
                    <filter name="active_orders" string="Commandes actives"
                            domain="[('state', 'in', ['confirmed', 'production', 'ready'])]"/>
                    <filter name="draft"     string="Brouillons" domain="[('state', '=', 'draft')]"/>
                    <filter name="done"      string="Livrées"    domain="[('state', '=', 'done')]"/>
                    <filter name="cancelled" string="Annulées"   domain="[('state', '=', 'cancelled')]"/>
                    <separator/>
                    <filter name="not_invoiced" string="Non facturées"
                            domain="[('invoice_status', '=', 'not_invoiced'), ('state', 'not in', ['draft', 'cancelled'])]"/>
                    <separator/>
                    <filter name="today" string="Aujourd'hui"
                            domain="[('date_order', '>=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                    <group expand="1" string="Grouper par">
                        <filter name="by_state"   string="État"          context="{'group_by': 'state'}"/>
                        <filter name="by_partner" string="Client"        context="{'group_by': 'partner_id'}"/>
                        <filter name="by_month"   string="Mois commande" context="{'group_by': 'date_order:month'}"/>
                    </group>
                </search>
            </field>
        </record>

    </data>
</odoo>
